# ============================================================
# Configuration Alpaca API
# Créez votre compte sur alpaca.markets pour obtenir ces clés
# ============================================================
ALPACA_API_KEY=votre_cle_ici
ALPACA_SECRET_KEY=votre_secret_ici

# Mode : TRUE pour Paper Trading (simulation), FALSE pour Live (argent réel)
PAPER_TRADING=TRUE

# ============================================================
# Symboles à suivre (séparés par des virgules, sans espaces)
# Exemples d'actions : AAPL, TSLA, MSFT, NVDA, AMZN, META, GOOGL
# Exemples d'ETFs   : SPY (S&P500), QQQ (Nasdaq), DIA (Dow Jones), IWM (Russell 2000)
# Pour ajouter un symbole : ajoutez-le simplement à la liste, ex: SYMBOLS=AAPL,SPY,TSLA,AMZN
# ============================================================
SYMBOLS=AAPL,SPY,QQQ,TSLA,MSFT,NVDA

# Timeframe d'analyse : 1Min, 5Min, 15Min, 1Hour, 1Day
TIMEFRAME=5Min

# ============================================================
# Paramètres de gestion du risque
# ============================================================
# Vente automatique si perte > X% depuis le prix d'entrée
STOP_LOSS_PERCENT=5.0

# Vente automatique si gain > X% depuis le prix d'entrée
TAKE_PROFIT_PERCENT=10.0

# Taille max d'une position = X% du solde disponible (ex: 10% sur 100 000$ = 10 000$ par trade)
MAX_POSITION_SIZE_PERCENT=10.0
